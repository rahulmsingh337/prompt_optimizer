{
  "entities": {
    "Optimization": {
      "title": "Optimized Prompt",
      "description": "An optimized prompt generated by NEXA",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The Google User UUID" },
        "roughRequest": { "type": "string", "description": "The initial user prompt text" },
        "optimizedPrompt": { "type": "string", "description": "Output structured optimized text" },
        "proTip": { "type": "string", "description": "A diagnostic expert recommendation" },
        "domain": { "type": "string", "description": "The selected optimization segment" },
        "targetAI": { "type": "string", "description": "The optimized platform target model" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "roughRequest", "optimizedPrompt", "timestamp"]
    },
    "Feedback": {
      "title": "Anonymous Feedback",
      "description": "Anonymous ratings and suggestions contributed to reinforcement learning",
      "type": "object",
      "properties": {
        "rating": { "type": "string", "enum": ["up", "down"], "description": "Up or down vote" },
        "comment": { "type": "string", "description": "Optional suggestion comment" },
        "domain": { "type": "string", "description": "The context domain" },
        "targetAI": { "type": "string", "description": "Target AI model" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["rating", "timestamp"]
    },
    "Preferences": {
      "title": "User Preferences",
      "description": "User specific app configuration preferences",
      "type": "object",
      "properties": {
        "targetAI": { "type": "string", "description": "The default target platform" },
        "modePreference": { "type": "string", "description": "The default style mode" },
        "domain": { "type": "string", "description": "The default domain focus" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["targetAI", "modePreference", "domain", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}/optimizations/{optimizationId}": {
      "schema": "Optimization",
      "description": "Google authenticated user prompt optimization history"
    },
    "/users/{userId}/preferences/{preferenceId}": {
      "schema": "Preferences",
      "description": "User account customized configuration preferences"
    },
    "/feedbacks/{feedbackId}": {
      "schema": "Feedback",
      "description": "Decentralized anonymized telemetry log entries"
    }
  }
}
